# =============================================================
# UniNet Connect — Variables de entorno (compartidas docker-compose)
# Copia este archivo a `.env` y ajusta los valores locales.
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=uninet
POSTGRES_PASSWORD=uninet_dev
POSTGRES_DB=uninet
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
BACKEND_RELOAD=true

# --- Frontend (Vite dev server) ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8000/api/v1
